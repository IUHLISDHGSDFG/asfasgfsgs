# 3. 策略组
proxy-groups:
  - name: "前置自动切换"
    type: fallback
    url: "http://www.gstatic.com/generate_204"
    interval: 30
    proxies: [前置-1, 前置-2]

  - name: "消费"
    type: select
    proxies: [专线-土耳其01, 专线-土耳其02, 专线-土耳其03, 专线-土耳其04, 专线-土耳其05]

  - name: "主线路"
    type: select
    proxies: [前置自动切换, DIRECT]

  # 中继链路 (Relay: 前置 -> 落地)
  - {name: "专线-土耳其01", type: "relay", proxies: ["前置自动切换", "落地-01"]}
  - {name: "专线-土耳其02", type: "relay", proxies: ["前置自动切换", "落地-02"]}
  - {name: "专线-土耳其03", type: "relay", proxies: ["前置自动切换", "落地-03"]}
  - {name: "专线-土耳其04", type: "relay", proxies: ["前置自动切换", "落地-04"]}
  - {name: "专线-土耳其05", type: "relay", proxies: ["前置自动切换", "落地-05"]}

# 4. 修复版分流规则
rules:
  # 拦截 QUIC (UDP 443)，解决浏览器报错的关键，不带 AND 逻辑以防报错
  - DST-PORT,443,REJECT,no-resolve

  # 强制 Google 所有相关子域名走土耳其“消费”组
  - DOMAIN-KEYWORD,google,消费
  - DOMAIN-SUFFIX,google.com,消费
  - DOMAIN-SUFFIX,google.com.tr,消费
  - DOMAIN-SUFFIX,googleplay.com,消费
  - DOMAIN-SUFFIX,googleapis.com,消费
  - DOMAIN-SUFFIX,gstatic.com,消费
  - DOMAIN-SUFFIX,ggpht.com,消费
  - DOMAIN-SUFFIX,googleusercontent.com,消费

  # 国内流量直连
  - GEOIP,CN,DIRECT
  - MATCH,主线路
